---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/base";

const versions = [
  { label: "Afspraak maken - versie 01", desc: "Datumkiezer met horizontale datumstrook", href: withBase("v1/") },
  { label: "Afspraak maken - versie 02", desc: "Datumkiezer met maandkalender", href: withBase("v2/") },
];
---

<BaseLayout title="Afspraak maken — Telenet">
  <main class="chooser">
    <div class="chooser-inner">
      <span class="logo" aria-label="Telenet">
        <svg width="48" height="48" viewBox="0 0 40 40" fill="none" aria-hidden="true">
          <rect width="40" height="40" rx="10" fill="var(--color-ink)" />
          <circle cx="14" cy="18" r="2.4" fill="#fff" />
          <circle cx="26" cy="18" r="2.4" fill="#fff" />
          <path d="M12.5 25c2.2 2.4 12.8 2.4 15 0" stroke="#fff" stroke-width="2.4" stroke-linecap="round" />
        </svg>
      </span>
      <h1 class="t-display">Afspraak maken</h1>
      <p class="t-body t-subtle sub">Kies een versie van de flow om te testen.</p>

      <nav class="links">
        {
          versions.map((v) => (
            <a class="version-link" href={v.href}>
              <span class="vl-body">
                <strong>{v.label}</strong>
                <span class="t-subtle vl-desc">{v.desc}</span>
              </span>
              <svg class="vl-chev" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          ))
        }
      </nav>
    </div>
  </main>
</BaseLayout>

<style>
  .chooser {
    min-height: 100dvh;
    background: var(--color-canvas);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl) var(--app-pad-x);
  }
  .chooser-inner {
    width: 100%;
    max-width: 480px;
  }
  .logo {
    display: inline-flex;
    margin-bottom: var(--space-lg);
  }
  h1.t-display {
    margin-bottom: var(--space-2xs);
  }
  .sub {
    margin-bottom: var(--space-xl);
  }
  .links {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .version-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-lg) var(--space-md);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    text-decoration: none;
    color: var(--color-ink);
    transition: transform 0.05s, box-shadow 0.15s;
  }
  .version-link:hover {
    box-shadow: var(--shadow-pop);
  }
  .version-link:active {
    transform: scale(0.99);
  }
  .vl-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .vl-body strong {
    font-family: var(--font-display);
    font-size: var(--type-title-lg-size);
    font-weight: 700;
  }
  .vl-desc {
    font-size: var(--type-body-sm-size);
  }
  .vl-chev {
    flex: none;
    color: var(--color-ink-subtle);
  }
</style>
