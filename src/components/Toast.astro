---
interface Props {
  message: string;
}
const { message } = Astro.props;
---
<div class="toast" data-toast hidden>
  <span class="check" aria-hidden="true">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M5 12.5l4.5 4.5L19 7.5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </span>
  <span class="msg" data-toast-msg>{message}</span>
  <button type="button" class="close" data-toast-close aria-label="Sluiten">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
  </button>
</div>

<style>
  .toast {
    position: fixed;
    left: 50%;
    bottom: calc(16px + env(safe-area-inset-bottom));
    transform: translateX(-50%);
    z-index: 40;
    width: calc(100% - 24px);
    max-width: 351px;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    background: var(--color-ink);
    color: #fff;
    border-radius: var(--radius-button);
    padding: var(--space-md);
    box-shadow: var(--shadow-pop);
    animation: toast-in 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .check {
    flex: none;
    width: 24px;
    height: 24px;
    border-radius: var(--radius-pill);
    background: #1db954;
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .msg {
    flex: 1;
    font-size: var(--type-body-sm-size);
    font-weight: 600;
  }
  .close {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.8);
    display: inline-flex;
    padding: 2px;
    border-left: 1px solid rgba(255, 255, 255, 0.2);
    padding-left: var(--space-sm);
  }
  @keyframes toast-in {
    from {
      transform: translate(-50%, 120%);
      opacity: 0;
    }
  }
</style>
