---
/* Footer nav. The wizard island updates the label, button text, disabled state,
   progress fill and Terug visibility per panel. */
---

<div class="stepnav" data-stepnav>
  <div class="progress" data-progress aria-hidden="true">
    <span class="seg" data-seg="1"></span>
    <span class="seg" data-seg="2"></span>
    <span class="seg" data-seg="3"></span>
  </div>
  <div class="row">
    <button type="button" class="btn btn--back" data-back hidden>
      <span class="ico">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </span>
      <span>Terug</span>
    </button>

    <span class="step-label" data-step-label>1/3</span>

    <button type="button" class="btn btn--next" data-next>
      <span data-next-label>Kies je datum en moment</span>
      <span class="ico ico--chip">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </span>
    </button>
  </div>
</div>

<style>
  .stepnav {
    padding: var(--space-sm) var(--app-pad-x) calc(var(--space-md) + env(safe-area-inset-bottom));
  }
  @media (min-width: 1024px) {
    .stepnav {
      padding: 0 var(--space-2xl) var(--space-md);
    }
    .stepnav .progress {
      margin: 0 calc(-1 * var(--space-2xl)) var(--space-md);
    }
  }
  .progress {
    display: flex;
    gap: 4px;
    margin-bottom: var(--space-sm);
  }
  .seg {
    height: 4px;
    flex: 1;
    border-radius: var(--radius-pill);
    background: var(--color-border-subtle);
    transition: background 0.2s;
  }
  .seg[data-active] {
    background: var(--color-action);
  }
  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }
  .step-label {
    color: var(--color-ink-subtle);
    font-size: var(--type-body-sm-size);
    font-variant-numeric: tabular-nums;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    border-radius: var(--radius-button);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--type-body-size);
    border: 2px solid transparent;
    padding: 10px 16px;
    transition: opacity 0.15s, transform 0.05s;
  }
  .btn:active {
    transform: translateY(1px);
  }
  .btn--back {
    background: var(--color-surface);
    border-color: var(--color-ink);
    color: var(--color-ink);
    padding-left: 10px;
  }
  .btn--back .ico {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 7px;
    background: var(--color-action);
  }
  .btn--next {
    background: var(--color-ink);
    color: #fff;
    padding-right: 10px;
  }
  .btn--next .ico--chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 7px;
    background: var(--color-action);
    color: var(--color-ink);
  }
  .btn[disabled] {
    opacity: 0.4;
    cursor: not-allowed;
  }
</style>
