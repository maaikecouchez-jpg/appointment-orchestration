---
import { config } from "../data/variables";
interface Props {
  address?: string;
}
const { address = config.address } = Astro.props;
---

<div class="address">
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path
      d="M12 21s7-5.686 7-11a7 7 0 1 0-14 0c0 5.314 7 11 7 11Z"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linejoin="round"></path>
    <circle cx="12" cy="10" r="2.4" stroke="currentColor" stroke-width="1.8"></circle>
  </svg>
  <span>{address}</span>
</div>

<style>
  .address {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--color-ink);
    font-size: var(--type-body-size);
    line-height: var(--type-body-line);
  }
  .address svg {
    flex: none;
    color: var(--color-ink);
  }
</style>
