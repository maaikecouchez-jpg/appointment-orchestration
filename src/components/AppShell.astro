---
/* Overlay shell used by the wizard + manage overlays.
   Mobile: full-bleed column. Desktop: full-screen with a header + scrolling
   content (centered by the panels) + a full-width sticky footer. */
interface Props {
  footer?: boolean;
}
const { footer = true } = Astro.props;
---

<div class="app-bg">
  <div class="app-frame">
    <main class="app-main">
      <slot />
    </main>
    {
      footer && (
        <div class="app-footer">
          <slot name="footer" />
        </div>
      )
    }
  </div>
</div>

<style>
  /* These shells live inside a fixed, full-viewport overlay, so the frame is
     bounded to the viewport height and the content area scrolls internally
     (on every screen size) while the footer stays pinned at the bottom. */
  .app-bg {
    height: 100dvh;
    background: var(--color-canvas);
    display: flex;
    flex-direction: column;
  }

  .app-frame {
    position: relative;
    width: 100%;
    flex: 1 1 auto;
    min-height: 0;
    background: var(--color-canvas);
    display: flex;
    flex-direction: column;
  }

  .app-main {
    flex: 1 1 auto;
    min-height: 0;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    display: flex;
    flex-direction: column;
  }

  .app-footer {
    flex: none;
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
  }

  @media (min-width: 1024px) {
    .app-footer {
      box-shadow: 0 -1px 0 var(--color-border-subtle);
    }
  }
</style>
