---
import { config } from "../../data/variables";
const icons = [
  '<path d="M5 6h14a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H9l-4 3V7a1 1 0 0 1 1-1Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>',
  '<circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.8"/><path d="M12 8v4l3 2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>',
];
---
<section class="gtk">
  <h2 class="t-caption head">Goed om te weten</h2>
  <ul>
    {
      config.goodToKnow.map((text, i) => (
        <li>
          <span class="ico" set:html={`<svg width="20" height="20" viewBox="0 0 24 24" fill="none">${icons[i % icons.length]}</svg>`} />
          <span>{text}</span>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .gtk {
    margin-top: var(--space-xs);
  }
  .head {
    color: var(--color-ink-subtle);
    font-weight: 600;
    margin-bottom: var(--space-sm);
  }
  ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  li {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    font-size: var(--type-body-sm-size);
    line-height: var(--type-body-line);
  }
  .ico {
    flex: none;
    color: var(--color-ink);
    margin-top: 1px;
  }
</style>
