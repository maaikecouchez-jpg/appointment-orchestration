---
interface Props {
  backLabel?: string;
  backHref?: string;
}
const { backLabel = "MyTelenet", backHref = "#" } = Astro.props;
const hasDesktopBack = backHref !== "#";
---

<!-- Mobile (yellow) header -->
<header class="gh gh--mobile">
  <a class="back" href={backHref} aria-label={backLabel}>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
    <span>{backLabel}</span>
  </a>
  <div class="tools">
    <button type="button" class="lang">NL
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
    <button type="button" class="ico" aria-label="Zoeken">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
    <button type="button" class="ico" aria-label="Meldingen">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 16V10a6 6 0 1 1 12 0v6l1.5 2H4.5L6 16Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M10 20a2 2 0 0 0 4 0" stroke="currentColor" stroke-width="1.8"/></svg>
    </button>
    <span class="avatar" aria-hidden="true">IV</span>
  </div>
</header>

<!-- Desktop top bar -->
<header class="gh gh--desktop">
  <div class="gh-left">
    {
      hasDesktopBack && (
        <a class="back" href={backHref}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>{backLabel}</span>
        </a>
      )
    }
  </div>
  <div class="gh-right">
    <button type="button" class="lang">NL
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
    <div class="search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      <span>Zoek op Telenet</span>
    </div>
    <button type="button" class="profile">
      <span class="avatar" aria-hidden="true">IV</span>
      <span>Louise</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
  </div>
</header>

<style>
  .gh {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    color: var(--color-ink);
  }
  .gh--desktop {
    display: none;
  }
  .gh--mobile {
    padding: var(--space-sm) var(--app-pad-x);
    background: var(--color-action);
  }

  .back {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: 600;
    font-size: var(--type-body-sm-size);
    color: var(--color-ink);
  }
  .tools {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
  }
  .lang {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    background: none;
    border: none;
    font-weight: 600;
    color: var(--color-ink);
  }
  .ico {
    background: none;
    border: none;
    color: var(--color-ink);
    display: inline-flex;
  }
  .avatar {
    width: 30px;
    height: 30px;
    border-radius: var(--radius-pill);
    background: var(--color-ink);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 1024px) {
    .gh--mobile {
      display: none;
    }
    .gh--desktop {
      display: flex;
      padding: var(--space-md) var(--space-2xl);
      background: var(--color-surface);
      border-bottom: 1px solid var(--color-border-subtle);
      min-height: 72px;
    }
    .gh-right {
      display: inline-flex;
      align-items: center;
      gap: var(--space-lg);
    }
    .search {
      display: inline-flex;
      align-items: center;
      gap: var(--space-xs);
      background: var(--color-canvas-neutral);
      border-radius: var(--radius-pill);
      padding: 8px 16px;
      color: var(--color-ink-subtle);
      font-size: var(--type-body-sm-size);
      min-width: 220px;
    }
    .profile {
      display: inline-flex;
      align-items: center;
      gap: var(--space-xs);
      background: none;
      border: none;
      color: var(--color-ink);
      font-weight: 600;
      font-size: var(--type-body-sm-size);
    }
    .profile .avatar {
      width: 28px;
      height: 28px;
    }
  }
</style>
