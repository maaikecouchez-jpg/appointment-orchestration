---
// Desktop-only left navigation (replaces the mobile bottom nav at ≥1024px).
const items = [
  { id: "mytelenet", label: "My Telenet", icon: '<path d="M4 11l8-6 8 6v8a1 1 0 0 1-1 1h-4v-5h-6v5H5a1 1 0 0 1-1-1v-8Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>' },
  { id: "products", label: "Products", icon: '<path d="M5 6h14a1 1 0 0 1 1 1v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a1 1 0 0 1 1-1Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M9 6V4.5A1.5 1.5 0 0 1 10.5 3h3A1.5 1.5 0 0 1 15 4.5V6" stroke="currentColor" stroke-width="1.8"/>' },
  { id: "payment", label: "Payment", icon: '<rect x="5" y="3" width="14" height="18" rx="2" stroke="currentColor" stroke-width="1.8"/><path d="M9 8h6M9 12h6M9 16h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>' },
  { id: "help", label: "Help", icon: '<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"/><path d="M9.5 9.5a2.5 2.5 0 1 1 3.5 2.3c-.7.3-1 .8-1 1.7M12 17h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>' },
  { id: "profile", label: "Profile", icon: '<circle cx="12" cy="8" r="3.5" stroke="currentColor" stroke-width="1.8"/><path d="M5 20a7 7 0 0 1 14 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>' },
];
const active = "products";
---
<aside class="sidebar">
  <div class="sb-top">
    <button type="button" class="sb-back" aria-label="Terug">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <span class="sb-logo" aria-label="Telenet">
      <svg width="28" height="28" viewBox="0 0 40 40" fill="none" aria-hidden="true">
        <rect width="40" height="40" rx="10" fill="var(--color-ink)" />
        <circle cx="14" cy="18" r="2.4" fill="#fff" />
        <circle cx="26" cy="18" r="2.4" fill="#fff" />
        <path d="M12.5 25c2.2 2.4 12.8 2.4 15 0" stroke="#fff" stroke-width="2.4" stroke-linecap="round" />
      </svg>
    </span>
  </div>
  <nav class="sb-nav">
    {
      items.map((item) => (
        <button type="button" class:list={["sb-item", { active: item.id === active }]}>
          <span class="sb-ico">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" set:html={item.icon} />
          </span>
          <span class="sb-label">{item.label}</span>
        </button>
      ))
    }
  </nav>
</aside>

<style>
  .sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .sidebar {
      display: flex;
      flex-direction: column;
      width: var(--sidebar-width);
      flex: none;
      background: var(--color-action);
      padding: var(--space-md) 0 var(--space-lg);
      position: sticky;
      top: 0;
      align-self: flex-start;
      height: 100dvh;
    }
    .sb-top {
      display: flex;
      align-items: center;
      gap: 2px;
      padding: 0 var(--space-sm) var(--space-2xl);
    }
    .sb-back {
      background: none;
      border: none;
      color: var(--color-ink);
      display: inline-flex;
    }
    .sb-logo {
      display: inline-flex;
    }
    .sb-nav {
      display: flex;
      flex-direction: column;
      gap: var(--space-lg);
      align-items: center;
    }
    .sb-item {
      background: none;
      border: none;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      color: var(--color-ink);
      width: 100%;
    }
    .sb-ico {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 32px;
      border-radius: var(--radius-pill);
    }
    .sb-label {
      font-size: 11px;
      font-weight: 500;
    }
    .sb-item.active .sb-ico {
      background: var(--color-ink);
      color: var(--color-action);
    }
    .sb-item.active .sb-label {
      font-weight: 700;
    }
  }
</style>
