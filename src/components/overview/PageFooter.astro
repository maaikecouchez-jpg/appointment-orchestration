---
// Desktop-only page footer (feedback + legal). Hidden on mobile.
const legal = [
  "Voorwaarden",
  "Consumenteninformatie",
  "Gebruikers met een beperking",
  "Wettelijke vermeldingen",
  "Herroepingsrecht",
];
---
<footer class="page-footer">
  <p class="pf-feedback">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 5h16v11H8l-4 3V5Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
    Fout gevonden of suggestie? <a href="#">Geef feedback</a>
  </p>
  <p class="pf-legal">{legal.join(" | ")}</p>
  <p class="pf-copy">© Telenet 2025</p>
</footer>

<style>
  .page-footer {
    display: none;
  }
  @media (min-width: 1024px) {
    .page-footer {
      display: block;
      margin-top: var(--space-2xl);
      padding-top: var(--space-md);
      color: var(--color-ink-subtle);
    }
    .pf-feedback {
      display: flex;
      align-items: center;
      gap: var(--space-xs);
      color: var(--color-ink);
      font-size: var(--type-body-sm-size);
      margin-bottom: var(--space-sm);
    }
    .pf-feedback a {
      color: var(--color-ink);
      text-decoration: underline;
      text-underline-offset: 3px;
      margin-left: 4px;
    }
    .pf-legal {
      font-size: var(--type-caption-size);
      padding-top: var(--space-sm);
      border-top: 1px solid var(--color-border-subtle);
    }
    .pf-copy {
      font-size: var(--type-caption-size);
      margin-top: 4px;
    }
  }
</style>
