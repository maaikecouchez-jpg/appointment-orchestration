---
interface Props {
  id: string;
  title?: string;
  /** "sheet" slides up from the bottom; "dialog" is centered. */
  variant?: "sheet" | "dialog";
}
const { id, title, variant = "sheet" } = Astro.props;
const hasFooter = Astro.slots.has("footer");
---

<div class="overlay" data-modal={id} data-variant={variant} hidden>
  <div class="backdrop" data-modal-close></div>
  <div class="surface" role="dialog" aria-modal="true" aria-label={title}>
    <button type="button" class="close" data-modal-close aria-label="Sluiten">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
      </svg>
    </button>
    <div class="content">
      {title && <h2 class="t-title modal-title">{title}</h2>}
      <slot />
    </div>
    {
      hasFooter && (
        <div class="modal-footer">
          <slot name="footer" />
        </div>
      )
    }
  </div>
</div>

<style>
  .overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
  }
  .backdrop {
    position: absolute;
    inset: 0;
    background: rgba(20, 19, 18, 0.45);
    animation: fade 0.2s ease;
  }
  .surface {
    position: relative;
    margin: auto auto 0;
    width: 100%;
    max-width: 100%;
    max-height: 92dvh;
    background: var(--color-canvas);
    border-radius: 24px 24px 0 0;
    display: flex;
    flex-direction: column;
    animation: slide-up 0.25s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  [data-variant="dialog"] .surface {
    margin: auto;
    width: calc(100% - 2 * var(--space-md));
    max-width: 420px;
    border-radius: 24px;
    max-height: 86dvh;
    animation: pop 0.2s ease;
  }

  /* Desktop: bottom sheets become right side-sheets; dialogs stay centered */
  @media (min-width: 1024px) {
    .surface {
      margin: 0 0 0 auto;
      width: 460px;
      max-width: 460px;
      height: 100dvh;
      max-height: 100dvh;
      border-radius: 0;
      animation: slide-left 0.28s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    [data-variant="dialog"] .surface {
      margin: auto;
      width: 100%;
      max-width: 420px;
      height: auto;
      max-height: 86dvh;
      border-radius: 24px;
      animation: pop 0.2s ease;
    }
  }
  .close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--color-ink);
    border-radius: var(--radius-pill);
    z-index: 1;
  }
  .content {
    padding: var(--space-xl) var(--app-pad-x) var(--space-md);
    overflow-y: auto;
  }
  .modal-title {
    margin-bottom: var(--space-sm);
    padding-right: 40px;
  }
  .modal-footer {
    padding: var(--space-sm) var(--app-pad-x) calc(var(--space-md) + env(safe-area-inset-bottom));
    border-top: 1px solid var(--color-border-subtle);
    background: var(--color-canvas);
  }

  @keyframes slide-up {
    from {
      transform: translateY(100%);
    }
  }
  @keyframes slide-left {
    from {
      transform: translateX(100%);
    }
  }
  @keyframes pop {
    from {
      transform: scale(0.96);
      opacity: 0;
    }
  }
  @keyframes fade {
    from {
      opacity: 0;
    }
  }
</style>
