---
interface Props {
  icon: "calendar" | "chat" | "info";
  label: string;
  sheet: string;
}
const { icon, label, sheet } = Astro.props;

const icons = {
  calendar: '<rect x="4" y="5" width="16" height="15" rx="3" stroke="currentColor" stroke-width="1.8"/><path d="M4 9h16M8 3v4M16 3v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>',
  chat: '<path d="M5 6h14a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H9l-4 3V7a1 1 0 0 1 1-1Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>',
  info: '<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"/><path d="M12 11v5M12 8h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>',
};
---

<button type="button" class="confirm-card" data-open-sheet={sheet}>
  <span class="cc-icon" aria-hidden="true">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" set:html={icons[icon]} />
  </span>
  <span class="cc-body">
    <span class="cc-label">{label}</span>
    <span class="cc-content"><slot /></span>
  </span>
  <span class="cc-edit" aria-hidden="true">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
      <path d="M4 20h4L18.5 9.5a2 2 0 0 0-2.83-2.83L5 17.5V20Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"></path>
    </svg>
  </span>
</button>

<style>
  .confirm-card {
    width: 100%;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-sm);
    align-items: start;
    text-align: left;
    background: var(--color-surface);
    border: 1.5px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-md);
    color: var(--color-ink);
    box-shadow: var(--shadow-card);
    transition: transform 0.05s, border-color 0.15s;
  }
  .confirm-card:hover {
    border-color: var(--color-border);
  }
  .confirm-card:active {
    transform: scale(0.99);
  }
  .cc-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-card);
    background: var(--color-action);
    color: var(--color-ink);
    flex: none;
  }
  .cc-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .cc-label {
    color: var(--color-ink-subtle);
    font-size: var(--type-body-sm-size);
  }
  .cc-content {
    font-size: var(--type-body-size);
    line-height: var(--type-body-line);
  }
  .cc-edit {
    color: var(--color-ink);
    flex: none;
    padding-top: 2px;
  }
</style>
